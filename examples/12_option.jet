// 12 — Option with pattern tests (M3, S32/S31).

fn find_even(limit: Int) -> Int? {
    for i in 1..limit {
        if i % 2 == 0 {
            return value(i);
        }
    }
    return null;
}

fn main() {
    if find_even(9) == value(n) {
        print(n);
    }
    if find_even(8) == null {
        print("none");
    }
}
